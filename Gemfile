# Solo necesario para previsualizar el sitio EN LOCAL.
# GitHub Pages construye el sitio automáticamente al hacer push:
# no hace falta instalar nada para publicar.
#
# Preview local (requiere Ruby):
#   gem install bundler
#   bundle install
#   bundle exec jekyll serve
#   → http://localhost:4000
source "https://rubygems.org"

gem "github-pages", group: :jekyll_plugins

# Windows: zona horaria + watcher
gem "tzinfo-data", platforms: [:mingw, :x64_mingw, :mswin]
gem "wdm", "~> 0.1", platforms: [:mingw, :x64_mingw, :mswin]
